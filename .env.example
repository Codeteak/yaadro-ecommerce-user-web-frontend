# Prefer setting the full base URL (includes /api)
NEXT_PUBLIC_API_BASE_URL=https://frontend.yaadro.online/api
#
# Backward-compatible (if you keep this, the app will treat it as https://.../api)
NEXT_PUBLIC_API_URL=https://frontend.yaadro.online

# Default shop ID for local development only.
# Used only when NODE_ENV is not "production".
NEXT_PUBLIC_SHOP_ID=c0000001-0000-4000-8000-000000000001

# Production tenant resolver endpoint (domain -> shopId).
# App sends GET ?host=<current-host>, expected response contains one of:
# { shopId } or { shop_id } or { data: { shopId } }.
# Example: https://api.yourdomain.com/api/tenant/resolve
NEXT_PUBLIC_TENANT_RESOLVER_URL=