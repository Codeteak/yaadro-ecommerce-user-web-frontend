# API Configuration
# Prefer setting the full base URL (includes /api)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
#
# Backward-compatible (if you keep this, the app will treat it as http://.../api)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Default Tenant ID for Development
# This will be used automatically if no tenant ID is set in localStorage or URL
NEXT_PUBLIC_DEFAULT_TENANT_ID=10001
